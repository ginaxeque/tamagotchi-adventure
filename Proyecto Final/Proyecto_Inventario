        print("2. [Administrador] Registrar Entrada de Proveedor (LIFO)")
        print("3. [Estratega] Configurar Parámetros y Costos Fijos")
        print("4. [Estratega] Simular Escenarios de Precios y Equilibrio")
        print("5. [Operador] Registrar Nueva Venta (Descarga LIFO)")
        print("6. Mostrar Inventario de la Cafetería y Alertas")
        print("7. Salir y Guardar Cambios")
        print("="*55)
        
        opcion = input("Selecciona una opción del flujo: ")
        
        if opcion == "1":
            print("\n--- GENERADOR DE PRODUCTO ---")
            id_p = input("Ingresa código ID único (ej. PROD-03): ")
            # JUSTIFICACIÓN RÚBRICA: Control de datos para impedir duplicación de IDs clave.
            if id_p in inventario:
                print("⚠️ Error: Este código ya está asignado a otro producto del menú.")
                continue
            nombre = input("Nombre del producto/bebida: ")
            tipo = input("Tipo (1. Fabricado [Receta] / 2. Comercializado [Listo]): ")
            tipo_str = "Fabricado" if tipo == "1" else "Comercializado"
            
            try:
                inventario[id_p] = Producto(id_p, nombre, tipo_str)
                print(f"✅ '{nombre}' añadido al menú con éxito.")
            except ValueError as e:
                print(f"⚠️ Error en validación de ID: {e}")
                
        elif opcion == "2":
            print("\n--- ADMINISTRADOR: ENTRADAS DESDE PROVEEDOR ---")
            id_p = input("Ingresa el ID del producto que reabastece: ")
            if id_p not in inventario:
                print("⚠️ Código de producto no registrado.")
                continue
                
            print("\n💡 Precios de Referencia de Proveedores:")
