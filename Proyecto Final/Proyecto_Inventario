            print(" - Mezcla Arábica Especial (Café): $160.00/kg (Costo por porción de 250g: $55.00)")
            
            try:
                costo = float(input("\nIngresa el costo base calculado del lote ($): "))
                cant = int(input("Cantidad de unidades que ingresan al stock: "))
                logistica = float(input("Costo de Logística / Envío del lote ($): "))
                
                # Ejecuta la inserción en la lista dinámica (.append)
                inventario[id_p].registrar_compra(costo, cant, logistica)
                print("✅ Compra guardada. El costo unitario se recalculará bajo método LIFO.")
            except ValueError:
                print("⚠️ Entrada cancelada: Se requieren valores numéricos.")
                
        elif opcion == "4":
            print("\n--- ESTRATEGA: ANÁLISIS DE PRECIOS Y VIABILIDAD DE OPERACIÓN ---")
            id_p = input("Ingresa el ID del producto a analizar (PROD-CB01 o PROD-BG02): ")
            if id_p not in inventario:
                print("⚠️ Producto no encontrado.")
                continue
            
            prod = inventario[id_p]
            res = prod.calcular_precios_estrategicos()
            
            print(f"\n📈 DIAGNÓSTICO FINANCIERO: {prod.nombre.upper()}")
            print(f" ├─ Costo de Última Compra Detectado (LIFO): ${prod.calcular_costo_unitario_lifo():.2f}")
            print(f" ├─ Precio con Margen Sugerido:            ${res['precio_margen']:.2f}")
