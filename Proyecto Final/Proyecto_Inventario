            print(f" └─ Precio Estratégico Aplicado:            ${res['precio_estrategico']:.2f}")
            print("-" * 55)
            print(f"📊 ANÁLISIS DE ABSORCIÓN DE COSTOS FIJOS ($71,400.00 MXN):")
            print(f" └─ Para que este producto cubra por sí solo la operación total de la cafetería,")
            print(f"    requieres vender un volumen crítico de: {res['punto_equilibrio_unidades']:.1f} unidades/mes.")
            
        elif opcion == "5":
            print("\n--- OPERADOR: PUNTO DE VENTA (SALIDAS) ---")
            id_p = input("ID del producto vendido: ")
            if id_p not in inventario:
                print("⚠️ Producto no válido.")
                continue
            try:
                cant_v = int(input("Cantidad de unidades ordenadas por el cliente: "))
                prec_v = float(input("Precio final cobrado en caja ($): "))
                
                # Ejecuta la descarga algorítmica LIFO y recupera el estatus de rentabilidad
                status_financiero = inventario[id_p].registrar_venta(cant_v, prec_v)
                print(f"\n✅ Ticket de venta procesado con éxito.")
                print(f" └─ Diagnóstico financiero de la venta: '{status_financiero}'")
            except ValueError as e:
                print(f"⚠️ Venta rechazada por el sistema: {e}")
                
        elif opcion == "6":
            print("\n--- REPORTE CONTROL DE INVENTARIO Y ALERTAS ---")
            for id_p, prod in inventario.items():
                # JUSTIFICACIÓN RÚBRICA: Parámetros específicos para detonar alertas de stock.
                alerta = prod.obtener_alerta_stock(limite_min=15, limite_max=80)
                print(f"• [{id_p}] {prod.nombre:<22} | Stock Actual: {prod.stock_actual:<4} u. | Costo LIFO: ${prod.calcular_costo_unitario_lifo():.2f} | Estado: {alerta}")
                
        elif opcion == "7":
            # JUSTIFICACIÓN RÚBRICA: Guardado forzoso en archivo JSON antes de cerrar.
            guardar_inventario(inventario)
            print("💾 Cambios respaldados exitosamente en 'inventario_emprendedor.json'.")
            print("☕ ¡Estructura de datos salvada! Éxito en la revisión del proyecto final.")
            break
        else:
            print("⚠️ Opción inválida del menú del flujo.")

